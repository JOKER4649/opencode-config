        source=ExtensionSource("dnf", package="gnome-shell-extension-background-logo"),
        fallback=ExtensionSource("extensions.gnome.org", extension_id=7364, version_tag=70689),
    ),
]

app = typer.Typer(no_args_is_help=True, help="Backup/restore GNOME Shell extensions")


def run(
    cmd: list[str],
    *,
    check: bool = True,
    capture: bool = True,
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(cmd, check=check, capture_output=capture, text=True)


def require_command(name: str) -> None:
    if not shutil.which(name):
        typer.echo(f"缺少必要命令：{name}", err=True)
        raise typer.Exit(1)


def gnome_shell_version() -> str:
    result = run(["gnome-shell", "--version"], check=False)
    return result.stdout.strip() or "unknown"


def gnome_shell_major() -> str:
    parts = gnome_shell_version().split()
    if len(parts) >= 3:
        return parts[2].split(".", maxsplit=1)[0]
    return ""


def list_extensions(*, enabled_only: bool = False) -> list[str]:
    cmd = ["gnome-extensions", "list"]
    if enabled_only:
        cmd.append("--enabled")
    result = run(cmd, check=False)
    return [line.strip() for line in result.stdout.splitlines() if line.strip()]


def installed_extensions() -> set[str]:
    return set(list_extensions(enabled_only=False))


def enabled_extensions() -> set[str]:
    result = run(
        ["gsettings", "get", "org.gnome.shell", "enabled-extensions"],
        check=False,
    )
    if result.returncode != 0:
        return set(list_extensions(enabled_only=True))
    try:
        parsed = ast.literal_eval(result.stdout.strip())
    except (SyntaxError, ValueError):
        return set(list_extensions(enabled_only=True))
    return {str(item) for item in parsed}


def fetch_version_tag(uuid: str) -> int | None:
    query_url = EGO_QUERY_URL + urllib.parse.quote(uuid)
    try:
        with urllib.request.urlopen(query_url, timeout=30) as response:
            data = json.load(response)
    except Exception:
        return None

    metadata = next(
        (item for item in data.get("extensions", []) if item.get("uuid") == uuid),
        None,
    )
    if not metadata:
        return None

    shell_version = gnome_shell_major()
    version_info = metadata.get("shell_version_map", {}).get(shell_version) or {}
    version_tag = version_info.get("pk")
    return int(version_tag) if version_tag else None


def download_and_install_from_ego(spec: ExtensionSpec, source: ExtensionSource) -> None:
    version_tag = source.version_tag or fetch_version_tag(spec.uuid)
    if not version_tag:
        typer.echo(f"! {spec.uuid}: 找不到 GNOME Shell {gnome_shell_major()} 相容版本，請手動安裝")
        return

    url = EGO_DOWNLOAD_URL.format(
        uuid=urllib.parse.quote(spec.uuid, safe=""),
        tag=version_tag,
    )
    with tempfile.TemporaryDirectory() as tmpdir:
        zip_path = f"{tmpdir}/{spec.uuid}.zip"
        with urllib.request.urlopen(url, timeout=60) as response:
            with open(zip_path, "wb") as file:
                file.write(response.read())
        run(["gnome-extensions", "install", "--force", zip_path], capture=False)
    typer.echo(f"✓ 已安裝 {spec.uuid}")


def install_missing(spec: ExtensionSpec, *, apply: bool) -> None:
    source = spec.source
    if source.type == "dnf":
        if not source.package:
            typer.echo(f"! {spec.uuid}: dnf source 缺少 package")
            return
        if not apply:
            typer.echo(f"+ 將安裝套件 {source.package} ({spec.uuid})")
            return
        require_command("sudo")
        run(["sudo", "dnf", "install", "-y", source.package], capture=False)
        return

    if source.type == "extensions.gnome.org":
        if not apply:
            tag = source.version_tag or "auto"
            typer.echo(f"+ 將從 extensions.gnome.org 安裝 {spec.uuid} (version_tag={tag})")
            return
        download_and_install_from_ego(spec, source)


def enable_extension(uuid: str, *, apply: bool) -> None:
    if not apply:
        typer.echo(f"+ 將啟用 {uuid}")
        return
    result = run(["gnome-extensions", "enable", uuid], check=False)
    if result.returncode == 0:
        typer.echo(f"✓ 已啟用 {uuid}")
    else:
        typer.echo(f"! 無法啟用 {uuid}: {result.stderr.strip()}", err=True)


def print_table(rows: list[tuple[str, str, str, str, str]]) -> None:
    headers = ("ID", "用途", "預期", "目前", "來源")
    widths = [len(header) for header in headers]
    for row in rows:
        for index, value in enumerate(row):
            widths[index] = max(widths[index], len(value))

    def fmt(row: tuple[str, str, str, str, str]) -> str:
        return "  ".join(value.ljust(widths[index]) for index, value in enumerate(row))

    typer.echo(fmt(headers))
    typer.echo(fmt(tuple("-" * width for width in widths)))
    for row in rows:
        typer.echo(fmt(row))


@app.command()
def status() -> None:
    """顯示腳本內建清單與目前系統狀態。"""
    require_command("gnome-extensions")
    installed = installed_extensions()
    enabled = enabled_extensions()
    rows: list[tuple[str, str, str, str, str]] = []

    for spec in EXTENSIONS:
        expected = "啟用" if spec.enabled else "停用"
        if spec.uuid in enabled:
            current = "已啟用"
        elif spec.uuid in installed:
            current = "已安裝未啟用"
        else:
            current = "未安裝"
        source = spec.source.package or spec.source.type
        rows.append((spec.uuid, spec.purpose, expected, current, source))

    typer.echo(f"GNOME Shell: {gnome_shell_version()}")
    typer.echo("")
    print_table(rows)


@app.command()
def current() -> None:
    """列出目前系統所有 GNOME extensions，方便更新 EXTENSIONS。"""
    require_command("gnome-extensions")
    enabled = enabled_extensions()
    for uuid in list_extensions(enabled_only=False):
        state = "enabled" if uuid in enabled else "disabled"
        typer.echo(f"{state:8}  {uuid}")


@app.command()
def restore(
    apply: Annotated[
        bool,
        typer.Option("--apply", help="實際安裝並啟用；預設只預覽"),
    ] = False,
) -> None:
    """依腳本內建清單安裝並啟用 GNOME extensions。"""
    for command in ("gnome-extensions", "gnome-shell"):
        require_command(command)

    installed = installed_extensions()
    enabled = enabled_extensions()

    if not apply:
        typer.echo("=== 預覽模式（加上 --apply 實際執行）===")

    for spec in EXTENSIONS:
        if spec.uuid not in installed:
            install_missing(spec, apply=apply)

            # 系統套件安裝後，gnome-extensions list 可能要 shell/session reload 才會看到。
            installed = installed_extensions()
            if spec.uuid not in installed and spec.fallback:
                if not apply:
                    typer.echo(f"+ 若套件不可用，將改用 fallback 安裝 {spec.uuid}")
                elif spec.fallback.type == "extensions.gnome.org":
                    download_and_install_from_ego(spec, spec.fallback)
                    installed = installed_extensions()

        if spec.enabled and spec.uuid not in enabled:
            enable_extension(spec.uuid, apply=apply)
            enabled = enabled_extensions()


if __name__ == "__main__":
    app()
