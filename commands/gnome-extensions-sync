#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.12"
# dependencies = ["typer"]
# ///
"""GNOME Shell extensions 備份與移植工具。

單一腳本即為備份來源：每個外掛的 id、用途、預期狀態與安裝來源都定義在
EXTENSIONS。移植到新機後執行：

  gnome-extensions-sync status
  gnome-extensions-sync restore          # 預覽
  gnome-extensions-sync restore --apply  # 實際安裝/啟用
"""

from __future__ import annotations

import ast
import json
import shutil
import subprocess
import tempfile
import urllib.parse
import urllib.request
from dataclasses import dataclass
from typing import Annotated, Literal

import typer

EGO_QUERY_URL = "https://extensions.gnome.org/extension-query/?search="
EGO_DOWNLOAD_URL = "https://extensions.gnome.org/download-extension/{uuid}.shell-extension.zip?version_tag={tag}"

SourceType = Literal["extensions.gnome.org", "dnf"]


@dataclass(frozen=True)
class ExtensionSource:
    type: SourceType
    extension_id: int | None = None
    version_tag: int | None = None
    package: str | None = None


@dataclass(frozen=True)
class ExtensionSpec:
    uuid: str
    purpose: str
    enabled: bool
    source: ExtensionSource
    fallback: ExtensionSource | None = None


# 這份清單就是備份來源。新增/移除外掛時，直接維護這裡。
EXTENSIONS: list[ExtensionSpec] = [
    ExtensionSpec(
        uuid="kimpanel@kde.org",
        purpose="Fcitx5/KDE kimpanel 輸入法狀態面板",
        enabled=True,
        source=ExtensionSource("extensions.gnome.org", extension_id=261, version_tag=69345),
    ),
    ExtensionSpec(
        uuid="dash-to-dock@micxgx.gmail.com",
        purpose="將 GNOME dash 變成常駐 dock",
        enabled=True,
        source=ExtensionSource("extensions.gnome.org", extension_id=307, version_tag=69959),
    ),
    ExtensionSpec(
        uuid="blur-my-shell@aunetx",
        purpose="Shell、面板、overview 等背景模糊效果",
        enabled=True,
        source=ExtensionSource("extensions.gnome.org", extension_id=3193, version_tag=69740),
    ),
    ExtensionSpec(
        uuid="just-perfection-desktop@just-perfection",
        purpose="調整/隱藏 GNOME Shell UI 元素",
        enabled=True,
        source=ExtensionSource("extensions.gnome.org", extension_id=3843, version_tag=68110),
    ),
    ExtensionSpec(
        uuid="appindicatorsupport@rgcjonas.gmail.com",
        purpose="AppIndicator / KStatusNotifierItem tray icon 支援",
        enabled=True,
        source=ExtensionSource("extensions.gnome.org", extension_id=615, version_tag=69296),
    ),
