{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    //"oh-my-openagent@latest",
    "oh-my-opencode-slim@latest",
    // "@ex-machina/opencode-anthropic-auth@1.7.5",
    "@slkiser/opencode-quota",
  ],
  "autoupdate": true,
  "model": "kimi-for-coding/k2p6",
  "small_model": "minimax-coding-plan/MiniMax-M2.1",
  "permission": {
    "bash": {
      "pkill -f *": "deny",
    },
    // 工作目錄外的檔案存取：「家目錄全允許 + 敏感例外」策略
    // 順序敏感：opencode 採「最後 match 勝出」，deny/ask 例外必須放在 allow 之後
    "external_directory": {
      // 家目錄與系統 temp：myconfig 管理 dotfile 的主場
      "~/**": "allow",
      "/tmp/**": "allow",
      "/var/tmp/**": "allow",
      // 高敏感金鑰類 → deny（外洩無法 revoke 重發）
      "~/.ssh/id_*": "deny",
      "~/.ssh/*.pem": "deny",
      "~/.gnupg/**": "deny",
      "~/.password-store/**": "deny",
      "~/.config/sops/**": "deny",
      // Token / credential 類 → ask（除錯時可手動放行，外洩可 revoke）
      "~/.aws/credentials*": "ask",
      "~/.config/gh/hosts.yml": "ask",
      "~/.config/gcloud/credentials*": "ask",
      "~/.config/gcloud/legacy_credentials/**": "ask",
      "~/.netrc": "ask",
      "~/.pgpass": "ask",
      "~/.kube/config": "ask",
      "~/.docker/config.json": "ask",
      "~/.npmrc": "ask",
      "~/.pnpmrc": "ask",
      "~/.yarnrc": "ask",
    },
  },
  "agent": {
    "explore": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
    "plan": {
      "disable": true,
    },
    "build": {
      "disable": true,
    },
  },
  "formatter": {
    // 全域停用預設 eslint formatter：由 Biome 接管 TS/JS lint+format；
    // 專案如需 eslint 可在自己的 opencode.json 覆蓋為 { "disabled": false, "command": [...] }
    "eslint": {
      "disabled": true
    },
    // Biome 處理 TS/JS/JSX/TSX/JSON/JSONC/CSS（格式化 + import 排序）
    // Wrapper 邏輯：專案有 biome.json/biome.jsonc 則用專案配置，否則 fallback 全局 myconfig/biome/
    "biome": {
      "command": [
        "~/myconfig/formatters/fmt-biome",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".json",
        ".jsonc",
        ".css",
      ],
    },
    // Prettier 處理 Biome 不擅長的 SFC 與 markup 格式（Vue/Astro/Svelte/MD/YAML/HTML/SCSS/GraphQL）
    // Wrapper 邏輯：專案有 .prettierrc*/prettier.config.* 則用專案配置（優先用專案 binary）
    "prettier": {
      "command": [
        "~/myconfig/formatters/fmt-prettier",
        "$FILE"
      ],
      "extensions": [
        ".vue",
        ".astro",
        ".svelte",
        ".md",
        ".mdx",
        ".yaml",
        ".yml",
        ".html",
        ".htm",
        ".scss",
        ".sass",
        ".less",
        ".graphql",
        ".gql",
      ],
    },
    // Ruff 處理 Python（.py/.pyi）
    // Wrapper 邏輯：專案有 ruff.toml / pyproject.toml[tool.ruff] 則用專案配置，否則 fallback 全局
    "ruff": {
      "command": [
        "~/myconfig/formatters/fmt-ruff",
        "$FILE"
      ],
      "extensions": [
        ".py",
        ".pyi"
      ],
    },
  },
  "mcp": {},
  "provider": {},
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "formatStyle": "grouped",
      "percentDisplayMode": "used",
    },
  },
}