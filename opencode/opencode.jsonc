{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@3.14.0",
    "opencode-claude-auth@1.4.9",
    "opencode-pty@latest"
  ],
  "autoupdate": true,
  "model": "opencode-go/minimax-m2.7", // 預設模型
  "small_model": "opencode-go/minimax-m2.7", // 可選的小模型
  "permission": {
    "bash": {
      // "rm *": "ask",
      "pkill -f *": "deny"
    }
  },
  "agent": {},
  "formatter": {
    "eslint": {
      "command": [
        "bunx",
        "eslint",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx"
      ]
    },
    "prettier": {
      "extensions": [
        ".html",
        ".css",
        ".md",
        ".json",
        ".yaml",
        ".yml",
        ".graphql",
        ".vue",
        ".svelte",
        ".less",
        ".scss"
      ]
    }
  },
  "mcp": {
    // oh-my-opencode 已內建
    // "playwright": {
    //   "enabled": true,
    //   "type": "local",
    //   "command": ["npx", "@playwright/mcp@latest"],
    // },
  },
  "provider": {}
}
