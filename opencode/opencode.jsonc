{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-opencode",
    "@franlol/opencode-md-table-formatter@latest"
  ],
  "autoupdate": true,
  "model": "anthropic/claude-sonnet-4-6", // 預設模型
  "small_model": "zai-coding-plan/glm-4.7", // 可選的小模型
  "permission": {
    "bash": {
      // "rm *": "ask",
      "pkill -f *": "deny"
    }
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "ask",
        "bash": "allow",
        "*": "allow"
      }
    }
  },
  "formatter": {
    "eslint": {
      "command": [
        "bunx",
        "eslint",
        "--fix",
        "$FILE"
      ],
      "extensions": [
        ".js",
        ".jsx",
        ".ts",
        ".tsx"
      ]
    },
    "prettier": {
      "extensions": [
        ".html",
        ".css",
        ".md",
        ".json",
        ".yaml",
        ".yml",
        ".graphql",
        ".vue",
        ".svelte",
        ".less",
        ".scss"
      ]
    }
  },
  "mcp": {
    // oh-my-opencode 已內建
    // "playwright": {
    //   "enabled": true,
    //   "type": "local",
    //   "command": ["npx", "@playwright/mcp@latest"],
    // },
  },
  "provider": {
    "cloudflare-ai-gateway": {
      "models": {
        "google-ai-studio/gemini-3-flash-preview": {},
        "google-ai-studio/gemini-3-pro-preview": {}
      }
    }
  }
}