{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    //"oh-my-openagent@latest",
    "oh-my-opencode-slim@latest",
    "@ex-machina/opencode-anthropic-auth@1.7.5",
    "@slkiser/opencode-quota",
  ],
  "autoupdate": true,
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "openai/gpt-5.4-mini",
  "permission": {
    "bash": {
      "pkill -f *": "deny",
    },
    // 工作目錄外的檔案存取：預設 "ask"（opencode default），但信任的 temp/cache 路徑直接放行
    // 其他未列出的外部路徑（如 ~/.ssh, ~/.config/gh/hosts.yml 等敏感目錄）仍維持詢問
    "external_directory": {
      "/tmp/**": "allow",
      "/var/tmp/**": "allow",
      "~/.cache/**": "allow",
      "~/.local/state/**": "allow",
    },
  },
  "agent": {
    "explore": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
    "plan": {
      "disable": true,
    },
    "build": {
      "disable": true,
    },
  },
  "formatter": {
    // 全域停用預設 eslint formatter：由 Biome 接管 TS/JS lint+format；
    // 專案如需 eslint 可在自己的 opencode.json 覆蓋為 { "disabled": false, "command": [...] }
    "eslint": { "disabled": true },
    // Biome 處理 TS/JS/JSX/TSX/JSON/JSONC/CSS（格式化 + import 排序）
    // Wrapper 邏輯：專案有 biome.json/biome.jsonc 則用專案配置，否則 fallback 全局 myconfig/biome/
    "biome": {
      "command": ["/home/joker/myconfig/formatters/fmt-biome", "$FILE"],
      "extensions": [
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".ts",
        ".tsx",
        ".mts",
        ".cts",
        ".json",
        ".jsonc",
        ".css",
      ],
    },
    // Prettier 處理 Biome 不擅長的 SFC 與 markup 格式（Vue/Astro/Svelte/MD/YAML/HTML/SCSS/GraphQL）
    // Wrapper 邏輯：專案有 .prettierrc*/prettier.config.* 則用專案配置（優先用專案 binary）
    "prettier": {
      "command": ["/home/joker/myconfig/formatters/fmt-prettier", "$FILE"],
      "extensions": [
        ".vue",
        ".astro",
        ".svelte",
        ".md",
        ".mdx",
        ".yaml",
        ".yml",
        ".html",
        ".htm",
        ".scss",
        ".sass",
        ".less",
        ".graphql",
        ".gql",
      ],
    },
    // Ruff 處理 Python（.py/.pyi）
    // Wrapper 邏輯：專案有 ruff.toml / pyproject.toml[tool.ruff] 則用專案配置，否則 fallback 全局
    "ruff": {
      "command": ["/home/joker/myconfig/formatters/fmt-ruff", "$FILE"],
      "extensions": [".py", ".pyi"],
    },
  },
  "mcp": {},
  "provider": {},
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "formatStyle": "grouped",
      "percentDisplayMode": "used",
    },
  },
}
