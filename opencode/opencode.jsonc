{
  "$schema": "https://opencode.ai/config.json",
  "plugin": [
    "oh-my-openagent@4.1.1",
    // "oh-my-opencode-slim@latest",
    // "@ex-machina/opencode-anthropic-auth@1.7.5",
    "opencode-zellij@latest",
    "@slkiser/opencode-quota",
  ],
  "autoupdate": true,
  "default_agent": "Hephaestus - Deep Agent",
  "model": "opencode-go/deepseek-v4-flash",
  "small_model": "opencode-go/deepseek-v4-flash",
  "permission": {
    "bash": {
      "pkill -f *": "deny",
    },
    // 工作目錄外的檔案存取：「家目錄全允許 + 敏感例外」策略
    // 順序敏感：opencode 採「最後 match 勝出」，deny/ask 例外必須放在 allow 之後
    "external_directory": {
      // 家目錄與系統 temp：myconfig 管理 dotfile 的主場
      "~/**": "allow",
      "/tmp/**": "allow",
      "/var/tmp/**": "allow",
      // 高敏感金鑰類 → deny（外洩無法 revoke 重發）
      "~/.ssh/id_*": "deny",
      "~/.ssh/*.pem": "deny",
      "~/.gnupg/**": "deny",
      "~/.password-store/**": "deny",
      "~/.config/sops/**": "deny",
      // Token / credential 類 → ask（除錯時可手動放行，外洩可 revoke）
      "~/.aws/credentials*": "ask",
      "~/.config/gh/hosts.yml": "ask",
      "~/.config/gcloud/credentials*": "ask",
      "~/.config/gcloud/legacy_credentials/**": "ask",
      "~/.netrc": "ask",
      "~/.pgpass": "ask",
      "~/.kube/config": "ask",
      "~/.docker/config.json": "ask",
      "~/.npmrc": "ask",
      "~/.pnpmrc": "ask",
      "~/.yarnrc": "ask",
    },
  },
  "agent": {
    "explore": {
      "disable": true,
    },
    "general": {
      "disable": true,
    },
    "plan": {
      "disable": true,
    },
    "build": {
      "disable": true,
    },
  },
  "formatter": {},
  "mcp": {},
  "provider": {},
  "experimental": {
    "quotaToast": {
      "enableToast": false,
      "showSessionTokens": true,
      "enabledProviders": "auto",
      "formatStyle": "grouped",
      "percentDisplayMode": "used",
    },
  },
}
