{
  "$schema": "https://raw.githubusercontent.com/code-yeongyu/oh-my-opencode/dev/assets/oh-my-opencode.schema.json",
  "default_run_agent": "hephaestus",
  "agents": {
    "sisyphus": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "ultrawork": {
        "model": "openai/gpt-5.5",
        "variant": "high"
      }
    },
    "hephaestus": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "prompt_append": "You are the primary implementation agent. Own the codebase. Explore, decide, execute. Use LSP and AST-grep aggressively.",
      "permission": {
        "edit": "allow",
        "bash": {
          "git": "allow",
          "test": "allow"
        }
      }
    },
    "prometheus": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high",
      "prompt_append": "Always interview first. Validate scope before planning."
    },
    "oracle": {
      "model": "opencode/gemini-3.1-pro",
      "variant": "high"
    },
    "librarian": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "explore": {
      "model": "opencode-go/deepseek-v4-flash",
      "variant": "high"
    },
    "multimodal-looker": {
      // "model": "opencode/gemini-3-flash"
      "model": "kimi-for-coding/k2p6"
    },
    "metis": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    },
    "momus": {
      "model": "openai/gpt-5.5",
      "variant": "high",
      "prompt_append": "Focus on code quality, edge cases, and test coverage."
    },
    "atlas": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    },
    "sisyphus-junior": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    }
  },
  "categories": {
    "visual-engineering": {
      // "model": "opencode/gemini-3.1-pro",
      // "variant": "high"
      "model": "kimi-for-coding/k2p6"
    },
    "ultrabrain": {
      "model": "openai/gpt-5.5",
      "variant": "high"
    },
    "deep": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "artistry": {
      // "model": "opencode/gemini-3.1-pro",
      // "variant": "high"
      "model": "kimi-for-coding/k2p6"
    },
    "quick": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    },
    "unspecified-high": {
      "model": "openai/gpt-5.4",
      "variant": "high"
    },
    "unspecified-low": {
      "model": "openai/gpt-5.4-mini",
      "variant": "high"
    },
    "writing": {
      "model": "opencode/gemini-3-flash"
    }
  },
  "auto_update": false,
  "runtime_fallback": false,
  "sisyphus_agent": {
    "default_builder_enabled": false,
    "tasks": {
      "enabled": true,
      "storage_path": ".sisyphus/tasks",
      "claude_code_compat": false
    }
  },
  "disabled_hooks": [
    "keyword-detector"
  ],
  "disabled_skills": [
    "playwright",
    "dev-browser"
  ],
  "background_task": {
    "defaultConcurrency": 10,
    "providerConcurrency": {
      "anthropic": 5,
      "openai": 10,
      "google": 15,
      "github-copilot": 10,
      "opencode": 15
    }
  },
  "browser_automation_engine": {
    "provider": "agent-browser"
  },
  "comment_checker": {
    "custom_prompt": "考慮這些註解欄位：`Intent`, `Reason`, `Constraints`, `Caveats`。皆為非必填，僅在程式行為、設計動機、使用限制或風險對理解有實質幫助時，才添加或修改。如要刪除註解，請謹慎考慮。"
  },
  "tmux": {
    "enabled": true,
    "layout": "main-vertical",
    "main_pane_size": 60,
    "main_pane_min_width": 120,
    "agent_pane_min_width": 40
  },
  "git_master": {
    "include_co_authored_by": false,
    "commit_footer": false
  },
  "team_mode": {
    "enabled": true,
    "tmux_visualization": true,
    "max_parallel_members": 4,
    "max_members": 8,
    "max_messages_per_run": 10000,
    "max_wall_clock_minutes": 120,
    "max_member_turns": 500,
    "message_payload_max_bytes": 32768,
    "recipient_unread_max_bytes": 262144,
    "mailbox_poll_interval_ms": 3000
  },
  "hashline_edit": true,
  "experimental": {
    "aggressive_truncation": true,
    // "task_system": true
  }
}
